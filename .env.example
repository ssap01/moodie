# Server
PORT=3000
NODE_ENV=development

# Auth (필수: 미설정 시 로그인/회원가입 500)
JWT_SECRET=your-secret-at-least-32-chars

# Frontend URL (비밀번호 재설정 링크, Google OAuth 리다이렉트)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# OMDb (영화 검색/동기화)
OMDB_API_KEY=your-omdb-api-key

# OpenAI (추천 1줄 이유 생성, 선택)
OPENAI_API_KEY=

# Google OAuth (선택) - Google Cloud Console에서 발급
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# 이메일 (비밀번호 찾기·이메일 찾기, 선택)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 영화 동기화 (선택)
# FORCE_MOVIE_SYNC=1
